APP_ENV=dev
SECRET_KEY=change-me

# --- docker (service-name hosts) — active defaults ---
DATABASE_URL=postgresql+psycopg://biteplate:biteplate@postgres:5432/biteplate
REDIS_URL=redis://redis:6379/0
BROKER_URL=redis://redis:6379/1          # RabbitMQ: amqp://guest:guest@rabbitmq:5672//
RESULT_BACKEND=redis://redis:6379/2

# --- local (no docker) — uncomment to run against localhost ---
# DATABASE_URL=postgresql+psycopg://biteplate:biteplate@localhost:5432/biteplate
# REDIS_URL=redis://localhost:6379/0
# BROKER_URL=redis://localhost:6379/1
# RESULT_BACKEND=redis://localhost:6379/2

SESSION_COOKIE=biteplate_session
TAX_RATE=0.12
DEFAULT_COMBO_DISCOUNT=0.10
